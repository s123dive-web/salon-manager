rules_version = '2';

// Firebase Storage holds vendor-bill proof files under shop/bills/<billId>/<file>
// (see src/lib/bills.js). The Firebase config is public, so these rules are the gate.
//
// WHY THIS FILE STILL USES AN EMAIL, WHEN THE DATABASE USES ROLES
// ----------------------------------------------------------------------------
// Storage rules cannot read the Realtime Database. There is a `firestore.get()`
// cross-service call, but no RTDB equivalent, so the shop/users/<uid>/role lookup
// that database.rules.json performs is simply not expressible here. The honest
// options are an email allowlist or custom auth claims (which need a backend /
// Admin SDK — out of scope for this app).
//
// Vendor bills are owner-only anyway, so an email allowlist costs nothing in
// practice: the set of people allowed to touch proofs is exactly {the owner}.
// If you add a second owner, add their email to the list below too.
//
// SETUP (do this once):
//   1. Replace OWNER_EMAIL below with the owner's sign-in email.
//      For more than one owner, use:
//        request.auth.token.email in ['a@x.com', 'b@x.com']
//   2. Deploy:  firebase deploy --only storage
service firebase.storage {
  match /b/{bucket}/o {
    // Vendor-bill proofs: owner-only, and capped at 10 MB to match MAX_PROOF_BYTES.
    match /shop/bills/{billId}/{fileName} {
      allow read: if request.auth != null
        && request.auth.token.email == 'OWNER_EMAIL';
      allow write: if request.auth != null
        && request.auth.token.email == 'OWNER_EMAIL'
        && request.resource.size < 10 * 1024 * 1024;
    }

    // Everything else is denied.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
